OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=./chroma_db
# Drop all Grade 8 Science PDFs into this folder — they'll all be ingested
SOURCES_DIR=./data/raw
# Fallback: single file mode (used only if SOURCES_DIR doesn't exist)
TEXTBOOK_PATH=./data/raw/NCERT_Class8_Science.pdf
TOP_K=6
CHUNK_SIZE=800
CHUNK_OVERLAP=100
SCORE_THRESHOLD=0.35
